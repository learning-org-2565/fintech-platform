# =============================================================================
# Terraform
# =============================================================================
**/.terraform/
**/*.tfstate
**/*.tfstate.*
**/*.tfstate.backup
**/terraform.tfstate.d/
**/.terraform.lock.hcl
**/*.tfplan
**/*.tfplan.json

# =============================================================================
# Terragrunt
# =============================================================================
**/.terragrunt-cache/
**/.terragrunt-module-manifest
**/.terragrunt-source-manifest
**/.terragrunt-source-version

# =============================================================================
# Sensitive variable files (never commit secrets)
# =============================================================================
**/*.tfvars
**/*.tfvars.json
**/*.auto.tfvars
!**/example.tfvars
!**/*.tfvars.example

# =============================================================================
# GCP / Google Cloud credentials
# =============================================================================
service-account*.json
*-service-account.json
credentials.json
gcloud/
application_default_credentials.json
*.p12
*.pfx
*.pem
*.key

# =============================================================================
# Environment / secret files
# =============================================================================
.env
.env.*
!.env.example
!.env.template
secrets.yml
secrets.yaml
*.secret

# =============================================================================
# IDE and editor files
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project
.history/

# =============================================================================
# OS generated files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
*.out

# =============================================================================
# Temporary / build artifacts
# =============================================================================
.tmp/
tmp/
temp/
dist/
build/
*.zip
*.tar.gz

# =============================================================================
# Node (if any tooling is added later)
# =============================================================================
node_modules/

# =============================================================================
# Python (if any scripts are added later)
# =============================================================================
__pycache__/
*.pyc
*.pyo
.venv/
venv/
